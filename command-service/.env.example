# Command Service - Variáveis de Ambiente
# Copie este arquivo para .env e ajuste conforme necessário

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant_order?schema=public"

# RabbitMQ
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# CORS - Origins permitidas (separadas por vírgula)
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# Porta padrão (será incrementada se estiver em uso)
PORT=4001

# Node environment
NODE_ENV="development"