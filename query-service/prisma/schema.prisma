generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OrderRead {
  id        String   @id
  tableId   String
  status    String
  total     Float
  items     Json
  updatedAt DateTime @default(now())

  @@index([tableId])
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String
  category    String
  price       Float
  available   Boolean @default(true)
}